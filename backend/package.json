{
  "name": "client-dashboard-backend",
  "version": "0.1.0",
  "private": true,
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "migrate:up": "psql $DATABASE_URL -f ./migrations/001_create_schema_up.sql",
